loadusr -W hal_manualtoolchange

# in case they were linked already
unlinkp iocontrol.tool-change
unlinkp iocontrol.tool-changed

net tool-change hal_manualtoolchange.change iocontrol.tool-change 
net tool-changed hal_manualtoolchange.changed iocontrol.tool-changed
net tool-prep-number hal_manualtoolchange.number iocontrol.tool-prep-number

