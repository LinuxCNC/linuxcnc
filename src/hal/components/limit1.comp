component limit1 "Limit the output signal to fall between min and max";
pin in real in;
pin out real out;
pin in real min_=-1e20;
pin in real max_=1e20;
option period no;
function _;
license "GPL";
author "Jeff Epler";
;;
FUNCTION(_) {
    rtapi_real tmp = in;
    if(tmp < min_) tmp = min_;
    if(tmp > max_) tmp = max_;
    out_set(tmp);
}
