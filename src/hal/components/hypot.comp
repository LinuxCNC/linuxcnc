component hypot "Three-input hypotenuse (Euclidean distance) calculator";
pin in real in0;
pin in real in1;
pin in real in2;
pin out real out "out = sqrt(*in0*^2^ + *in1*^2^ + *in2*^2^)";
option period no;
function _;
license "GPL";
author "Jeff Epler";
;;
#include <rtapi_math.h>
FUNCTION(_) {
    rtapi_real a = in0, b = in1, c = in2;
    out_set(sqrt(a*a + b*b + c*c));
}
