component millturn "Switchable kinematics for a mill-turn machine";

description
"""
.if \\n[.g] .mso www.tmac

This is a switchable kinematics module using 3 cartesian linear joints (XYZ)
and 1 angular joint (A). The module contains two kinematic models:

type0 (default) is a mill (XYZA) configuration with A being a
rotary axis.

type1 is a turn (Z-YX) configuration with A configured to be a spindle.

For an example configuration, run the sim config: 'configs/sim/axis/vismach/millturn/millturn.ini'.

Further explanations can be found in the README in 'configs/sim/axis/vismach/millturn'.

millturn.comp was constructed by modifying the template file:
userkins.comp.

For more information on how to modify userkins.comp run: $ man
userkins.   Also, see additional information inside: 'userkins.comp'.

For information on kinematics in general see the kinematics
document chapter (docs/src/motion/kinematics.txt) and for
switchable kinematics in particular see the switchkins document
chapter (docs/src/motion/switchkins.txt)

""";
pin in u32 demo_in = 0 "example input pin";
pin out u32 demo_out = 0 "example output pin, echoes 'demo-in' after homing";
pin out s32 fpin = 0 "pin to demonstrate use of a conventional (non-kinematics) function fdemo";
param rw float param_rw = 0 "example read-write parameter";
param r  float param_ro = 0 "example read-only parameter";
pin out bit kinstype_is_0 = 1 "Indicates mill (type 0) kinematics active";
pin out bit kinstype_is_1 = 0 "Indicates turn (type 1) kinematics active";
function fdemo;
gmi_provide kins;
license "GPL";
author "David Mueller";
;;

// ─── GMI kinematics callbacks ───
//
// These functions implement the kins_callbacks_t interface.
// modcompile wires them into the callbacks struct automatically
// via the gmi_provide directive.
//
// With the ctx parameter, gmi_kins_* callbacks can access the
// component instance by casting:
//   inst_t *__comp_inst = (inst_t *)ctx;
// This enables use of HAL pin convenience macros.

static int32_t switchkins_type;

static kins_kinematics_type_t gmi_kins_type(void *ctx)
{
    (void)ctx;
    return KINS_BOTH;
}

static int32_t gmi_kins_switchable(void *ctx)
{
    (void)ctx;
    return 1;
}

static int32_t gmi_kins_switch(void *ctx, int32_t new_switchkins_type)
{
    inst_t *__comp_inst = (inst_t *)ctx;
    switchkins_type = new_switchkins_type;
    gomc_log_infof(__comp_inst->env->log, __comp_inst->name, "kinematicsSwitch(): type=%d", switchkins_type);
    switch (switchkins_type) {
        case 0: gomc_log_infof(__comp_inst->env->log, __comp_inst->name, "kinematicsSwitch:TYPE0");
                kinstype_is_0 = 1;
                kinstype_is_1 = 0;
                break;
        case 1: gomc_log_infof(__comp_inst->env->log, __comp_inst->name, "kinematicsSwitch:TYPE1");
                kinstype_is_0 = 0;
                kinstype_is_1 = 1;
                break;
       default: gomc_log_errorf(__comp_inst->env->log, __comp_inst->name, "kinematicsSwitch:BAD VALUE <%d>",
                switchkins_type);
                kinstype_is_0 = 0;
                kinstype_is_1 = 0;
                return -1; // FAIL
    }
    return 0;
}

static int32_t gmi_kins_forward(
    void *ctx,
    const double joints[KINS_MAX_JOINTS],
    kins_pose_t *pos,
    uint64_t fflags,
    uint64_t *iflags)
{
    (void)ctx;
    (void)fflags;
    (void)iflags;

    // Switchable forward kinematics:
    // type 0 (mill): XYZA identity
    // type 1 (turn): Z-YX remap with A as spindle
    switch (switchkins_type) {
        case 0:
            pos->x = joints[0];
            pos->y = joints[1];
            pos->z = joints[2];
            pos->a = joints[3];
            break;
        case 1:
            pos->x = joints[2];
            pos->y = -joints[1];
            pos->z = joints[0];
            pos->a = joints[3];
            break;
    }
    // unused coordinates:
    pos->b = 0;
    pos->c = 0;
    pos->u = 0;
    pos->v = 0;
    pos->w = 0;
    return 0;
}

static int32_t gmi_kins_inverse(
    void *ctx,
    const kins_pose_t *pos,
    double joints[KINS_MAX_JOINTS],
    uint64_t iflags,
    uint64_t *fflags)
{
    (void)ctx;
    (void)iflags;
    (void)fflags;

    // Switchable inverse kinematics:
    // [KINS]JOINTS=4 required for this module
    switch (switchkins_type) {
        case 0:
            joints[0] = pos->x;
            joints[1] = pos->y;
            joints[2] = pos->z;
            joints[3] = pos->a;
            break;
        case 1:
            joints[2] = pos->x;
            joints[1] = -pos->y;
            joints[0] = pos->z;
            joints[3] = pos->a;
            break;
    }
    return 0;
}

FUNCTION(fdemo) {
   // This function can be added to a thread (addf) for
   // purposes not related to the kinematics functions.
   if (fpin == 0) {
       GOMC_LOG_INFO("fdemo function added to thread");
   }
   fpin++;
   // example HAL pin echo (only works in FUNCTION context)
   demo_out = demo_in;
}
