component mux2 "Select from one of two input values";
pin in bool sel;
pin out real out "Follows the value of *in0* if *sel* is FALSE, or *in1* if *sel* is TRUE";
pin in real in1;
pin in real in0;
option period no;
function _;
license "GPL";
author "Jeff Epler";
see_also "mux4(9), mux8(9), mux16(9), mux_generic(9).";
;;
FUNCTION(_) {
    if(sel) out_set(in1);
    else out_set(in0);
}
