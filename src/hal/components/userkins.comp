component userkins"Template for user-built kinematics";

description
"""
.if \\n[.g] .mso www.tmac

The userkins.comp file is a template for creating
kinematics that can be user-built using modcompile.

The unmodified userkins component can be used
as a kinematics file for a machine with identity
kinematics for an xyz machine employing 3 joints
(motors).

\\fBUSAGE:\\fR

  1) Copy the userkins.comp file to a user-owned
     directory (\\fBmydir\\fR).

  2) Edit the functions gmi_kins_forward() and
     gmi_kins_inverse() as required
  3) If required, add hal pins using the pin/param
     directives in the header section
  4) Build and install the component using modcompile:
     $ cd \\fBmydir\\fR
     $ [sudo] modcompile --install userkins.comp
  5) Specify userkins in an ini file as:
     \\fB[KINS]\\fR
     \\fBKINEMATICS=userkins\\fR
     \\fBJOINTS=3\\fR
     # the number of JOINTS must agree with the
     # number of joints used in your modified userkins.comp
  6) To use a different component name, rename the file
     (example mykins.comp) and change all instances of
     'userkins' to 'mykins'

\\fBNOTES:\\fR
  1  Hal pins declared in the header section are accessible
     in kinematics functions via the convenience macros
     (e.g. pin name 'in' becomes the macro 'in').

  2  The gmi_provide directive automatically registers
     the kinematics callbacks with the motion controller.
""";
pin in u32 demo_in = 0 "example input pin";
pin out u32 demo_out = 0 "example output pin, echoes 'demo-in' after homing";
pin out s32 fpin = 0 "pin to demonstrate use of a conventional (non-kinematics) function fdemo";
param rw float param_rw = 0 "example read-write parameter";
param r  float param_ro = 0 "example read-only parameter";
function fdemo;
gmi_provide kins;
license "GPL";
author "Dewey Garrett";
;;

// ─── GMI kinematics callbacks ───
//
// These functions implement the kins_callbacks_t interface.
// modcompile wires them into the callbacks struct automatically
// via the gmi_provide directive.
//
// With the ctx parameter, gmi_kins_* callbacks can access the
// component instance by casting:
//   inst_t *__comp_inst = (inst_t *)ctx;
// This enables use of HAL pin convenience macros.

static kins_kinematics_type_t gmi_kins_type(void *ctx)
{
    (void)ctx;
    return KINS_IDENTITY;
}

static int32_t gmi_kins_switchable(void *ctx)
{
    (void)ctx;
    return 0;
}

static int32_t gmi_kins_switch(void *ctx, int32_t switchkins_type)
{
    (void)ctx;
    (void)switchkins_type;
    return -1; // not switchable
}

static int32_t gmi_kins_forward(
    void *ctx,
    const double joints[KINS_MAX_JOINTS],
    kins_pose_t *pos,
    uint64_t fflags,
    uint64_t *iflags)
{
    (void)ctx;
    (void)fflags;
    (void)iflags;

    // [KINS]JOINTS=3
    pos->x = joints[0]; // X coordinate
    pos->y = joints[1]; // Y coordinate
    pos->z = joints[2]; // Z coordinate
    // unused coordinates:
    pos->a = 0;
    pos->b = 0;
    pos->c = 0;
    pos->u = 0;
    pos->v = 0;
    pos->w = 0;
    return 0;
}

static int32_t gmi_kins_inverse(
    void *ctx,
    const kins_pose_t *pos,
    double joints[KINS_MAX_JOINTS],
    uint64_t iflags,
    uint64_t *fflags)
{
    (void)ctx;
    (void)iflags;
    (void)fflags;

    // Update the kinematic joints specified by the
    // [KINS]JOINTS setting (3 required for this template).
    joints[0] = pos->x; // joint 0
    joints[1] = pos->y; // joint 1
    joints[2] = pos->z; // joint 2
    return 0;
}

FUNCTION(fdemo) {
   // This function can be added to a thread (addf) for
   // purposes not related to the kinematics functions.
   if (fpin == 0) {
       GOMC_LOG_INFO("fdemo function added to thread");
   }
   fpin++;
   // example HAL pin echo (only works in FUNCTION context)
   demo_out = demo_in;
}
