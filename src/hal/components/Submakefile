# ---------------------------------------------------------------------------
# cmod build rules: .comp → modcompile → .c → gcc -shared → ../cmod/*.so
# ---------------------------------------------------------------------------


CMOD_INCLUDE := gomc/pkg/cmodule
CMOD_CFLAGS  := -fPIC -Os -Wall -shared -o

# Step 1: .comp → .c via modcompile
objects/cmod/%.c: hal/components/%.comp ../bin/modcompile
	$(ECHO) "Preprocessing cmod $(notdir $<)"
	@mkdir -p $(dir $@)
	$(Q)../bin/modcompile --preprocess $< > $@

# Step 2: .c → .so via gcc -shared
../cmod/%.so: objects/cmod/%.c
	$(ECHO) "Compiling cmod $(notdir $@)"
	@mkdir -p $(dir $@)
	$(Q)$(CC) -fPIC -Os -Wall -shared -I $(CMOD_INCLUDE) -o $@ $< $(CMOD_LDFLAGS) -lm

# Step 2b: kinematics comps need the GMI kins API header path.
# These override the generic pattern rule above for kins modules.
CMOD_GMI_KINS_API := gomc/generated/gmi/kins
CMOD_KINS_CFLAGS := -fPIC -Os -Wall -shared -I $(CMOD_INCLUDE) -I $(CMOD_GMI_KINS_API)

../cmod/userkins.so: objects/cmod/userkins.c $(CMOD_GMI_KINS_API)/kins_api.h
	$(ECHO) "Compiling cmod (kins) $(notdir $@)"
	@mkdir -p $(dir $@)
	$(Q)$(CC) $(CMOD_KINS_CFLAGS) -o $@ $< $(CMOD_LDFLAGS) -lm

../cmod/millturn.so: objects/cmod/millturn.c $(CMOD_GMI_KINS_API)/kins_api.h
	$(ECHO) "Compiling cmod (kins) $(notdir $@)"
	@mkdir -p $(dir $@)
	$(Q)$(CC) $(CMOD_KINS_CFLAGS) -o $@ $< $(CMOD_LDFLAGS) -lm

../cmod/xyzab_tdr_kins.so: objects/cmod/xyzab_tdr_kins.c $(CMOD_GMI_KINS_API)/kins_api.h
	$(ECHO) "Compiling cmod (kins) $(notdir $@)"
	@mkdir -p $(dir $@)
	$(Q)$(CC) $(CMOD_KINS_CFLAGS) -o $@ $< $(CMOD_LDFLAGS) -lm

# Step 2c: homecomp needs the GMI home + mot API header paths.
CMOD_GMI_HOME_API := gomc/generated/gmi/home
CMOD_GMI_MOT_API := gomc/generated/gmi/mot
CMOD_HOME_CFLAGS := -fPIC -Os -Wall -shared -I $(CMOD_INCLUDE) -I $(CMOD_GMI_HOME_API) -I $(CMOD_GMI_MOT_API)

../cmod/homecomp.so: objects/cmod/homecomp.c $(CMOD_GMI_HOME_API)/home_api.h $(CMOD_GMI_MOT_API)/mot_api.h
	$(ECHO) "Compiling cmod (home) $(notdir $@)"
	@mkdir -p $(dir $@)
	$(Q)$(CC) $(CMOD_HOME_CFLAGS) -o $@ $< $(CMOD_LDFLAGS) -lm

# Step 2d: manualtoolchange needs the GMI manualtoolchange API header path.
CMOD_GMI_MTC_API := gomc/generated/gmi/manualtoolchange
CMOD_MTC_CFLAGS := -fPIC -Os -Wall -shared -I $(CMOD_INCLUDE) -I $(CMOD_GMI_MTC_API)

