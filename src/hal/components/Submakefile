	$(ECHO) "Compiling cmod (manualtoolchange) $(notdir $@)"
	@mkdir -p $(dir $@)
	$(Q)$(CC) $(CMOD_MTC_CFLAGS) -o $@ $< $(CMOD_LDFLAGS) -lm

