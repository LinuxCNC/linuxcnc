{
    (void)ctx; (void)njoints;
    return 0;
}

static int32_t gmi_home_do_homing(void *ctx) { (void)ctx; return 1; } // always "just finished"

static int32_t gmi_home_write_out_pins(void *ctx, int32_t njoints)
