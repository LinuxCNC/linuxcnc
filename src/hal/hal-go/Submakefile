# hal-go Submakefile - Golang HAL component bindings
# Only included if BUILD_GOLANG is true (Go 1.21+ detected)

ifeq ($(BUILD_GOLANG),yes)

# Go build settings
HAL_GO_DIR := hal/hal-go
HAL_GO_SRC := $(addprefix $(HAL_GO_DIR)/, \
    hal.go \
    component.go \
    pin.go \
    types.go \
    errors.go \
    cgo.go \
    doc.go)

# Build directory for absolute paths
TOP := $(shell cd ..; pwd)

# CGO environment for building
HAL_GO_CGO_CFLAGS := -I$(TOP)/src/hal -I$(TOP)/src/rtapi -I$(TOP)/include -DULAPI
HAL_GO_CGO_LDFLAGS := -L$(TOP)/lib -llinuxcnchal

# Build the passthrough example
HAL_GO_EXAMPLES := ../bin/passthrough ../bin/str-sender ../bin/str-receiver

../bin/passthrough: $(HAL_GO_SRC) $(HAL_GO_DIR)/examples/passthrough/main.go $(HAL_GO_DIR)/examples/passthrough/go.mod ../lib/liblinuxcnchal.so
	@echo "Building hal-go passthrough example"
	cd $(HAL_GO_DIR)/examples/passthrough && \
	CGO_ENABLED=1 \
	CGO_CFLAGS="$(HAL_GO_CGO_CFLAGS)" \
	CGO_LDFLAGS="$(HAL_GO_CGO_LDFLAGS)" \
	$(GO) build -o $(TOP)/bin/passthrough .

# Build the string test components
../bin/str-sender: $(HAL_GO_SRC) $(HAL_GO_DIR)/tests/str-sender/main.go $(HAL_GO_DIR)/tests/str-sender/go.mod ../lib/liblinuxcnchal.so
	@echo "Building hal-go str-sender test component"
	cd $(HAL_GO_DIR)/tests/str-sender && \
	CGO_ENABLED=1 \
	CGO_CFLAGS="$(HAL_GO_CGO_CFLAGS)" \
	CGO_LDFLAGS="$(HAL_GO_CGO_LDFLAGS)" \
	$(GO) build -o $(TOP)/bin/str-sender .

../bin/str-receiver: $(HAL_GO_SRC) $(HAL_GO_DIR)/tests/str-receiver/main.go $(HAL_GO_DIR)/tests/str-receiver/go.mod ../lib/liblinuxcnchal.so
	@echo "Building hal-go str-receiver test component"
	cd $(HAL_GO_DIR)/tests/str-receiver && \
	CGO_ENABLED=1 \
	CGO_CFLAGS="$(HAL_GO_CGO_CFLAGS)" \
	CGO_LDFLAGS="$(HAL_GO_CGO_LDFLAGS)" \
	$(GO) build -o $(TOP)/bin/str-receiver .

# Copy hal-go package files for RIP builds
HAL_GO_SHARE_FILES := \
	../share/linuxcnc/hal-go/hal.go \
	../share/linuxcnc/hal-go/component.go \
	../share/linuxcnc/hal-go/pin.go \
	../share/linuxcnc/hal-go/types.go \
	../share/linuxcnc/hal-go/errors.go \
	../share/linuxcnc/hal-go/cgo.go \
	../share/linuxcnc/hal-go/doc.go \
	../share/linuxcnc/hal-go/go.mod

../share/linuxcnc/hal-go/%.go: $(HAL_GO_DIR)/%.go
	$(ECHO) Copying hal-go file $(notdir $@)
	@mkdir -p $(dir $@)
	$(Q)cp -f $< $@

../share/linuxcnc/hal-go/go.mod: $(HAL_GO_DIR)/go.mod
	$(ECHO) Copying hal-go file $(notdir $@)
	@mkdir -p $(dir $@)
	$(Q)cp -f $< $@

# Copy hal-go-template files for RIP builds
HAL_GO_TEMPLATE_FILES := \
	../share/linuxcnc/hal-go-template/README.md \
	../share/linuxcnc/hal-go-template/Makefile \
	../share/linuxcnc/hal-go-template/go.mod \
	../share/linuxcnc/hal-go-template/main.go \
	../share/linuxcnc/hal-go-template/.gitignore

../share/linuxcnc/hal-go-template/%: $(HAL_GO_DIR)/../hal-go-template/%
	$(ECHO) Copying hal-go-template file $(notdir $@)
	@mkdir -p $(dir $@)
	$(Q)cp -f $< $@

# Targets
TARGETS += $(HAL_GO_EXAMPLES) $(HAL_GO_SHARE_FILES) $(HAL_GO_TEMPLATE_FILES)

# Test target
.PHONY: test-hal-go
test-hal-go: $(HAL_GO_EXAMPLES)
	@echo "Running hal-go integration tests..."
	$(HAL_GO_DIR)/tests/run_tests.sh

# Clean
clean: hal-go-clean
.PHONY: hal-go-clean
hal-go-clean:
	rm -f $(HAL_GO_EXAMPLES)
	rm -rf $(HAL_GO_DIR)/examples/passthrough/passthrough
	rm -rf $(HAL_GO_DIR)/tests/str-sender/str-sender
	rm -rf $(HAL_GO_DIR)/tests/str-receiver/str-receiver
	rm -f $(HAL_GO_SHARE_FILES)
	rm -f $(HAL_GO_TEMPLATE_FILES)

# Install
install: hal-go-install
.PHONY: hal-go-install
hal-go-install: $(HAL_GO_EXAMPLES) $(HAL_GO_SHARE_FILES) $(HAL_GO_TEMPLATE_FILES)
	$(DIR) $(DESTDIR)$(EMC2_HOME)/bin
	$(FILE) $(HAL_GO_EXAMPLES) $(DESTDIR)$(EMC2_HOME)/bin/
	# Install hal-go package for external component development
	$(DIR) $(DESTDIR)$(datadir)/linuxcnc/hal-go
	$(FILE) ../share/linuxcnc/hal-go/hal.go $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	$(FILE) ../share/linuxcnc/hal-go/component.go $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	$(FILE) ../share/linuxcnc/hal-go/pin.go $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	$(FILE) ../share/linuxcnc/hal-go/types.go $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	$(FILE) ../share/linuxcnc/hal-go/errors.go $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	$(FILE) ../share/linuxcnc/hal-go/cgo.go $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	$(FILE) ../share/linuxcnc/hal-go/doc.go $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	$(FILE) ../share/linuxcnc/hal-go/go.mod $(DESTDIR)$(datadir)/linuxcnc/hal-go/
	# Install template for external component development
	$(DIR) $(DESTDIR)$(datadir)/linuxcnc/hal-go-template
	$(FILE) ../share/linuxcnc/hal-go-template/README.md $(DESTDIR)$(datadir)/linuxcnc/hal-go-template/
	$(FILE) ../share/linuxcnc/hal-go-template/Makefile $(DESTDIR)$(datadir)/linuxcnc/hal-go-template/
	$(FILE) ../share/linuxcnc/hal-go-template/go.mod $(DESTDIR)$(datadir)/linuxcnc/hal-go-template/
	$(FILE) ../share/linuxcnc/hal-go-template/main.go $(DESTDIR)$(datadir)/linuxcnc/hal-go-template/
	$(FILE) ../share/linuxcnc/hal-go-template/.gitignore $(DESTDIR)$(datadir)/linuxcnc/hal-go-template/

endif # BUILD_GOLANG
