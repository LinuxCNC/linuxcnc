# Add include path for lcec private headers and ethercat library to RT compile flags.
# RTFLAGS is appended here (before RTCFLAGS is constructed from it in Makefile).
RTFLAGS += -I$(BASEPWD)/$(LCEC_DIR) $(ETHERCAT_CFLAGS)

# Explicit link rule: ethercat_rt needs -lethercat beyond the standard -lm.
../rtlib/ethercat_rt.so:
	$(ECHO) Linking $@
	$(Q)ld -d -r -o objects/ethercat_rt.tmp $^
	$(Q)objdump -w -j .rtapi_export -t objects/ethercat_rt.tmp \
	    | awk 'BEGIN{print "{ global :"} /rtapi_exported_/{printf("%s;\n", substr($$6,16))} END{print "local : * ; };"}' \
	    > objects/ethercat_rt.ver
	$(Q)$(CC) -shared -Bsymbolic -Wl,--version-script,objects/ethercat_rt.ver \
	    -o $@ $^ -lm $(ETHERCAT_LIBS) $(LDFLAGS)
	$(Q)chmod -x $@

# ---------- Userspace cmod plugin: ethercat.so ----------

LCEC_CONF_SRCS := \
    $(LCEC_DIR)/conf.c \
    $(LCEC_DIR)/conf_util.c \
    $(LCEC_DIR)/conf_icmds.c

USERSRCS += $(LCEC_CONF_SRCS)
$(call TOOBJSDEPS, $(LCEC_CONF_SRCS)): EXTRAFLAGS += \
    -fPIC -DULAPI -URTAPI -I$(BASEPWD)/$(LCEC_DIR) -I$(BASEPWD) $(ETHERCAT_CFLAGS)

../cmod/ethercat.so: $(call TOOBJS, $(LCEC_CONF_SRCS)) ../lib/liblinuxcnchal.so.0
	$(ECHO) Linking $(notdir $@)
	@mkdir -p ../cmod
	$(Q)$(CC) -shared -o $@ $^ $(LDFLAGS) -lexpat

TARGETS += ../cmod/ethercat.so

endif # BUILD_ETHERCAT
