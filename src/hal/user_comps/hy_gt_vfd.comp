component hy_gt_vfd "Huanyang GT-series VFD Modbus driver";

pin out float SetF                       "Frequency command (Hz)";
pin out float OutF                       "Output frequency (Hz)";
pin out float OutA                       "Output current (A)";
pin out float RoTT                       "Motor RPM";
pin out float DCV                        "DC bus voltage (V)";
pin out float ACV                        "AC output voltage (V)";
pin out float Rone                       "Register 0x300E";
pin out float Rtwo                       "Register 0x300F";
pin out float Tmp                        "Inverter temperature (C)";
pin out float OutC                       "Output current (A, high res)";
pin out float RH                         "Run hours";
pin out float PPO                        "Power on hours";
pin out float voltage                    "Mapped output voltage";
pin out bit at_speed                     "True when within speed tolerance";
pin out bit is_stopped                   "True when output frequency is 0";
pin out bit modbus_ok                    "True after 10 successful transactions";
pin out signed error_count               "Modbus error counter";
pin in float speed_command               "Speed command (RPM)";
pin in bit spindle_on                    "Spindle on/off";
pin in bit spindle_fwd                   "Spindle forward direction";
pin in bit spindle_rev                   "Spindle reverse direction";
pin in bit enable                        "Enable VFD control";

param rw float loop_time = 0.1          "Polling period (seconds)";
param rw float nameplate_HZ = 50        "Motor nameplate frequency (Hz)";
param rw float nameplate_RPM = 1410     "Motor nameplate RPM";
param rw float max_freq = 50            "VFD max frequency (Hz)";
param rw float tolerance = 0.01         "Speed tolerance for at-speed";

option userspace yes;
option extra_setup yes;
option data vfd_data;

modparam string device "Serial device (default: /dev/ttyS0)";
modparam int baud = 38400 "Baud rate";
modparam int bits = 8 "Data bits";
modparam string parity "Parity: even, odd, or none (default: none)";
modparam int stopbits = 1 "Stop bits";
modparam int target = 1 "Modbus slave address";
modparam int modbus_debug = 0 "Enable Modbus debug output";

license "GPLv2 or greater";
;;
/*
    hy_gt_vfd.comp

    Userspace cmod to control a Huanyang GT-series VFD via Modbus RTU.

