component gs2_vfd "Automation Direct GS2 VFD Modbus driver";

pin out float motor_RPM                  "Motor speed (RPM)";
pin out float frequency_out              "Output frequency (Hz)";
pin out float output_current             "Output current (A)";
pin out float DC_bus_voltage             "DC bus voltage (V)";
pin out float output_voltage             "Output voltage (V)";
pin out float inverter_temperature       "Inverter temperature (C)";
pin out float motor_load_pct             "Motor load (%)";
pin out signed status_register           "VFD status register";
pin out signed error_count               "Modbus error counter";
pin out bit at_speed                     "True when within speed tolerance";
pin out bit is_stopped                   "True when output frequency is 0";
pin out bit modbus_ok                    "True after 10 successful transactions";
pin out bit is_e_stopped                 "True when in E-stop condition";
pin in float speed_command               "Speed command (RPM)";
pin in bit spindle_on                    "Spindle on/off";
pin in bit spindle_fwd                   "Spindle forward";
pin in bit spindle_rev                   "Spindle reverse";
pin in bit err_reset                     "Reset VFD fault";
pin in bit enable                        "Enable VFD control";

param rw float loop_time = 0.1          "Polling period (seconds)";
param rw float nameplate_HZ = 60        "Motor nameplate frequency (Hz)";
param rw float nameplate_RPM = 1730     "Motor nameplate RPM";
param rw float max_freq = 60            "VFD max frequency (Hz)";
param rw float tolerance = 0.01         "Speed tolerance for at-speed";
param rw float accel_time = 10.0        "Acceleration time (seconds)";
param rw float decel_time = 10.0        "Deceleration time (seconds)";
param rw float braking_resistor = 0     "Braking resistor percent";

option userspace yes;
option extra_setup yes;
option data vfd_data;

modparam string device "Serial device (default: /dev/ttyS0)";
modparam int baud = 38400 "Baud rate";
modparam int bits = 8 "Data bits";
modparam string parity "Parity: even, odd, or none (default: odd)";
modparam int stopbits = 1 "Stop bits";
modparam int target = 1 "Modbus slave address";
modparam int modbus_debug = 0 "Enable Modbus debug output";

license "GPLv2 or greater";
;;
