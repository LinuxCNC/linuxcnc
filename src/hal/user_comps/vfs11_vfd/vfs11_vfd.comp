component vfs11_vfd "Toshiba VF-S11 VFD Modbus driver";

pin out signed status                    "VFD status register (FD01)";
pin out signed trip_code                 "Current trip code";
pin out signed alarm_code                "Alarm monitor bitmap";
pin out float frequency_command          "Frequency command sent to VFD (Hz)";
pin out float frequency_out              "Actual output frequency (Hz)";
pin out float output_current_percentage  "Output current (%)";
pin out float output_voltage_percentage  "Output voltage (%)";
pin out float motor_RPM                  "Estimated motor speed (RPM)";
pin out float inverter_load_percentage   "Inverter load factor (%)";
pin out float current_load_percentage    "Load current (%)";
pin out float max_rpm                    "Calculated max RPM from VFD limit";
pin out float frequency_limit            "Upper frequency limit from VFD (Hz)";
pin out bit at_speed                     "True when within speed tolerance";
pin out bit is_stopped                   "True when output frequency is 0";
pin out bit is_e_stopped                 "True when emergency stop active";
pin out bit modbus_ok                    "True after 10 successful transactions";
pin out signed error_count               "Modbus error count";
pin in float speed_command               "Speed command (RPM)";
pin in bit spindle_on                    "Spindle run command";
pin in bit spindle_fwd                   "Spindle forward direction";
pin in bit spindle_rev                   "Spindle reverse (output, follows fwd)";
pin in bit DC_brake                      "Engage DC brake (stops spindle)";
pin in bit err_reset                     "Reset VFD fault";
pin in bit estop                         "Trigger VFD emergency stop";
pin in bit jog_mode                      "Jog run mode";
pin in bit enable                        "Enable bus control of VFD";
pin in bit acceleration_pattern          "Select accel/decel pattern 2 (F500/F501)";
pin in bit max_speed                     "Skip non-essential register reads";

param rw float loop_time = 0.1           "Polling period (seconds)";
param rw float nameplate_HZ = 50         "Motor nameplate frequency (Hz)";
param rw float nameplate_RPM = 1410      "Motor nameplate RPM";
param rw float rpm_limit = 2000          "RPM limit";
param rw float tolerance = 0.01          "Speed tolerance for at-speed";

option userspace yes;
option extra_setup yes;
option data vfd_data;

modparam string device "Serial device (default: /dev/ttyS0)";
modparam int baud = 19200 "Baud rate";
modparam int bits = 8 "Data bits";
modparam string parity "Parity: even, odd, or none (default: even)";
modparam int stopbits = 1 "Stop bits";
modparam int target = 1 "Modbus slave address";
modparam int modbus_debug = 0 "Enable Modbus debug output";
modparam int pollcycles = 10 "Read less-important registers every N cycles";
modparam int reconnect_delay = 1 "Seconds between reconnect attempts";
modparam string inifile "INI file for VFD parameters (optional)";
modparam string section "INI section name (default: VFS11)";
modparam int report_device = 0 "Report device info at startup";
modparam string type "Connection type: rtu, tcpserver, or tcpclient (default from INI)";
modparam string tcpdest "TCP destination IP (default: 127.0.0.1)";
modparam int tcp_port = 1502 "TCP port number";

license "GPLv2 or greater";
;;
