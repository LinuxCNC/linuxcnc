component hy_vfd "Huanyang VFD driver (custom protocol)";

pin out float SetF                       "Frequency command (Hz)";
pin out float OutF                       "Output frequency (Hz)";
pin out float OutA                       "Output current (A)";
pin out float Rott                       "Motor RPM";
pin out float DCV                        "DC bus voltage";
pin out float ACV                        "AC voltage";
pin out float Cont                       "Cont register";
pin out float Tmp                        "Inverter temperature";
pin out float CNTR                       "Control request register";
pin out float CNST                       "Control status response";
pin out bit CNST_run                     "CNST Run bit";
pin out bit CNST_jog                     "CNST Jog bit";
pin out bit CNST_command_rf              "CNST command reverse/forward";
pin out bit CNST_running                 "CNST Running bit";
pin out bit CNST_jogging                 "CNST Jogging bit";
pin out bit CNST_running_rf              "CNST running reverse/forward";
pin out bit CNST_bracking                "CNST braking bit";
pin out bit CNST_track_start             "CNST track start bit";
pin out float frequency_command          "Calculated frequency command (Hz)";
pin out float max_freq                   "Max operating frequency (PD005)";
pin out float base_freq                  "Base frequency (PD004)";
pin out float freq_lower_limit           "Lower frequency limit (PD011)";
pin out float rated_motor_voltage        "Rated motor voltage (PD141)";
pin out float rated_motor_current        "Rated motor current (PD142)";
pin out unsigned motor_poles             "Number of motor poles (PD143)";
pin out float rated_motor_rev            "Motor max speed RPM";
pin out bit hycomm_ok                    "True after 10 successful transactions";
pin out float max_rpm                    "Calculated max RPM";
pin out float spindle_speed_fb           "Spindle speed feedback (RPM)";
pin out bit spindle_at_speed             "True when at commanded speed";
pin in float speed_command               "Speed command (RPM)";
pin in bit spindle_forward               "Spindle forward";
pin in bit spindle_reverse               "Spindle reverse";
pin in bit spindle_on                    "Spindle on";
pin in bit enable                        "Enable VFD communication";
pin in float spindle_at_speed_tolerance = 0.02 "Speed tolerance for at-speed";

param rw float loop_time = 0.1          "Polling period (seconds)";
param rw signed error_count              "Communication error counter";
param rw float retval                    "Return value of last operation";

option userspace yes;
option extra_setup yes;
option data vfd_data;

modparam string device "Serial device (default: /dev/ttyS0)";
modparam int baud = 19200 "Baud rate";
modparam int bits = 8 "Data bits";
modparam string parity "Parity: even, odd, or none (default: even)";
modparam int stopbits = 1 "Stop bits";
modparam int target = 1 "Slave address";
modparam int debug_flag = 0 "Enable debug output";
modparam float cfg_max_freq = 0 "Max frequency override (Hz, PD005)";
modparam float cfg_min_freq = 0 "Min frequency override (Hz, PD011)";
modparam float cfg_base_freq = 0 "Base frequency override (Hz, PD004)";
modparam float cfg_motor_voltage = 0 "Motor voltage override (V, PD141)";
modparam float cfg_motor_current = 0 "Motor current override (A, PD142)";
modparam float cfg_motor_speed = 0 "Motor max speed override (RPM)";
modparam int cfg_motor_poles = 0 "Motor poles override (PD143)";

license "GPLv2 or greater";
;;
