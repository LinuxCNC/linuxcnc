	cp $^ $@

# ---------------------------------------------------------------------------
# cmod builds: hostmot2.so + transport drivers
# ---------------------------------------------------------------------------
# The hostmot2 core and each transport driver are separate cmod .so files.
# The core provides hm2_serial API and consumes hm2_llio API.
# Transport drivers provide hm2_llio API.
# ---------------------------------------------------------------------------


HM2_DIR := hal/drivers/mesa-hostmot2

# ═══════════════════════════════════════════════════════════════════════════════
# hostmot2.so — core module
# ═══════════════════════════════════════════════════════════════════════════════

HM2_CORE_SRCS := \
    $(HM2_DIR)/hostmot2.c \
    $(HM2_DIR)/abs_encoder.c \
    $(HM2_DIR)/bitfile.c \
    $(HM2_DIR)/bspi.c \
    $(HM2_DIR)/dpll.c \
    $(HM2_DIR)/encoder.c \
    $(HM2_DIR)/hm2_serial_provider.c \
    $(HM2_DIR)/inm.c \
    $(HM2_DIR)/inmux.c \
    $(HM2_DIR)/ioport.c \
    $(HM2_DIR)/led.c \
    $(HM2_DIR)/oneshot.c \
    $(HM2_DIR)/outm.c \
    $(HM2_DIR)/pins.c \
    $(HM2_DIR)/pktuart.c \
    $(HM2_DIR)/pwmgen.c \
    $(HM2_DIR)/raw.c \
    $(HM2_DIR)/rcpwmgen.c \
    $(HM2_DIR)/resolver.c \
    $(HM2_DIR)/sserial.c \
    $(HM2_DIR)/ssr.c \
    $(HM2_DIR)/stepgen.c \
    $(HM2_DIR)/tp_pwmgen.c \
    $(HM2_DIR)/tram.c \
    $(HM2_DIR)/uart.c \
    $(HM2_DIR)/watchdog.c \
    $(HM2_DIR)/xy2mod.c

HM2_CMOD_CFLAGS := \
    -fPIC -Os -Wall -Wextra \
    -DUSPACE -D_GNU_SOURCE -Drealtime \
    -fno-strict-aliasing -fwrapv \
    -Irtapi/pci \
    -Irtapi/parport \
    -I. -I../include \
    -I$(HM2_DIR) \
    -Igomc/pkg/cmodule \
    -Igomc/generated/gmi/hm2_llio \
    -Igomc/generated/gmi/hm2_serial

HM2_CMOD_LDFLAGS = $(CMOD_LDFLAGS) -lrtapi_core -lm
HM2_CMOD_LDFLAGS_PCI = $(HM2_CMOD_LDFLAGS) -lrtapi_pci
HM2_CMOD_LDFLAGS_PARPORT = $(HM2_CMOD_LDFLAGS) -lrtapi_parport

../cmod/hostmot2.so: $(HM2_CORE_SRCS) \
                     $(wildcard $(HM2_DIR)/*.h) \
                     $(wildcard gomc/pkg/cmodule/gomc_*.h) \
                     gomc/generated/gmi/hm2_llio/hm2_llio_api.h \
                     gomc/generated/gmi/hm2_serial/hm2_serial_api.h \
                     | headers ../lib/librtapi_core.so
	$(ECHO) "Compiling cmod hostmot2.so"
	@mkdir -p $(dir $@)
	$(Q)$(CC) -shared $(HM2_CMOD_CFLAGS) \
	    -o $@ $(HM2_CORE_SRCS) \
	    $(HM2_CMOD_LDFLAGS_PCI)

TARGETS += ../cmod/hostmot2.so
modules: ../cmod/hostmot2.so

