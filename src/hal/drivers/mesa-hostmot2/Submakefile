
$(patsubst ./hal/drivers/mesa-hostmot2/%,../include/%,$(wildcard ./hal/drivers/mesa-hostmot2/*.h)): ../include/%.h: ./hal/drivers/mesa-hostmot2/%.h
	cp $^ $@
