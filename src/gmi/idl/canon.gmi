# Canon Callback Table API
#
# Replaces the ~110 free C functions in canon.hh with a per-instance
# callback table. Each Interp instance receives its own canon_t at
# construction. The table carries a void *ctx that the implementation
# uses to reach its private state (CanonConfig, interp_list, emcStatus).
#
# Three implementations exist:
#   1. emccanon (task) — converts units, queues NML messages to motion
#   2. saicanon (SAI)  — standalone interpreter dummy/simulator
#   3. gcodemodule     — Python backplot/preview forwarding
#
# Design: MILLTASK_CLEANUP.md Phase 1

@api canon
@author "Thomas Kramer (canon.hh)"
@author "Sascha Ittner <sascha.ittner@modusoft.de>"
@license "GPL Version 2"
@version 1
@prefix canon
@rest_export false

# ─── Types ───

type ControlPoint {
    x: f64
    y: f64
    w: f64
}

# Enum parameters (CANON_UNITS, CANON_PLANE, CANON_MOTION_MODE, CANON_DIRECTION,
# CANON_AXIS) are passed as i32 in the callback table to avoid header coupling
# with canon.hh. Constants are defined in canon.hh.

# ─── Initialization ───

@doc "Initialize canon state"
func init_canon()

# ─── Representation / Offsets ───

@doc "Set G5x work coordinate system offset"
func set_g5x_offset(origin: i32, x: f64, y: f64, z: f64, a: f64, b: f64, c: f64, u: f64, v: f64, w: f64)

@doc "Set G92 offset"
func set_g92_offset(x: f64, y: f64, z: f64, a: f64, b: f64, c: f64, u: f64, v: f64, w: f64)

@doc "Set XY rotation angle"
func set_xy_rotation(t: f64)

@doc "Update the end point (no motion)"
func update_end_point(x: f64, y: f64, z: f64, a: f64, b: f64, c: f64, u: f64, v: f64, w: f64)

@doc "Set length units"
func use_length_units(units: i32)

@doc "Select active plane"
func select_plane(plane: i32)

# ─── Free Space Motion ───

@doc "Set traverse (rapid) rate"
func set_traverse_rate(rate: f64)

@doc "Rapid move to position"
func straight_traverse(lineno: i32, x: f64, y: f64, z: f64, a: f64, b: f64, c: f64, u: f64, v: f64, w: f64)

# ─── Feed & Motion Control ───

@doc "Set feed rate"
func set_feed_rate(rate: f64)

@doc "Set feed reference mode (1=workpiece, 2=xyz)"
