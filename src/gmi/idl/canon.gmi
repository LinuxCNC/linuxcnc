@doc "Start speed-feed synchronization"
func start_speed_feed_synch(spindle: i32, feed_per_revolution: f64, velocity_mode: i32)

@doc "Stop speed-feed synchronization"
func stop_speed_feed_synch()

# ─── Machining Functions ───

@doc "Arc feed move"
func arc_feed(lineno: i32, first_end: f64, second_end: f64, first_axis: f64, second_axis: f64, rotation: i32, axis_end_point: f64, a: f64, b: f64, c: f64, u: f64, v: f64, w: f64)

@doc "Linear feed move"
func straight_feed(lineno: i32, x: f64, y: f64, z: f64, a: f64, b: f64, c: f64, u: f64, v: f64, w: f64)

@doc "NURBS feed move"
func nurbs_feed(lineno: i32, control_points: []ControlPoint, k: u32)

@doc "Rigid tapping cycle"
func rigid_tap(lineno: i32, x: f64, y: f64, z: f64, scale: f64)

@doc "Straight probe move"
func straight_probe(lineno: i32, x: f64, y: f64, z: f64, a: f64, b: f64, c: f64, u: f64, v: f64, w: f64, probe_type: u8)

# ─── Motion Control ───

@doc "Stop motion immediately"
