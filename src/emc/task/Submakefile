

# stdglue.so — standard remap prolog/epilog handlers
STDGLUE_SRCS := emc/task/stdglue.c
USERSRCS += $(STDGLUE_SRCS)

$(call TOOBJSDEPS, $(STDGLUE_SRCS)): EXTRAFLAGS += -fPIC \
    -Igomc/generated/gmi/interp_ext -Igomc/generated/gmi/interp_ctx \
    -Igomc/pkg/cmodule

$(call TOOBJSDEPS, $(STDGLUE_SRCS)): gomc/generated/gmi/interp_ext/interp_ext_api.h
$(call TOOBJSDEPS, $(STDGLUE_SRCS)): gomc/generated/gmi/interp_ctx/interp_ctx_api.h

../cmod/stdglue.so: $(call TOOBJS, $(STDGLUE_SRCS))
	$(ECHO) Linking $(notdir $@)
	@mkdir -p ../cmod
	@$(CC) -shared -o $@ $^ $(CMOD_LDFLAGS)
TARGETS += ../cmod/stdglue.so

