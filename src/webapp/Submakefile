# ---------------------------------------------------------------------------
# Web application builds (Vue 3 + TypeScript via Vite)
# ---------------------------------------------------------------------------
# Builds web applications from src/webapp/<app>/ into
# share/gomc/webapp/<app>/ for serving by gomc-server.
# ---------------------------------------------------------------------------


WEBAPP_DIR := webapp
WEBAPP_DEST := ../share/gomc/webapp

# --- halscope ---

HALSCOPE_WEBAPP_SRC := $(WEBAPP_DIR)/halscope
HALSCOPE_WEBAPP_DEST := $(WEBAPP_DEST)/halscope

# Use a stamp file to track the build
HALSCOPE_WEBAPP_STAMP := $(HALSCOPE_WEBAPP_DEST)/.build-stamp

# Source files that trigger a rebuild
HALSCOPE_WEBAPP_SRCS := $(shell find $(HALSCOPE_WEBAPP_SRC)/src -type f 2>/dev/null) \
	$(HALSCOPE_WEBAPP_SRC)/index.html \
	$(HALSCOPE_WEBAPP_SRC)/package.json \
	$(HALSCOPE_WEBAPP_SRC)/vite.config.ts \
	$(HALSCOPE_WEBAPP_SRC)/tsconfig.json

# npm install stamp
HALSCOPE_NPM_STAMP := $(HALSCOPE_WEBAPP_SRC)/node_modules/.install-stamp

$(HALSCOPE_NPM_STAMP): $(HALSCOPE_WEBAPP_SRC)/package.json
	$(ECHO) "Installing halscope webapp dependencies"
	$(Q)cd $(HALSCOPE_WEBAPP_SRC) && npm install --no-audit --no-fund
	$(Q)touch $@

# Generated TS clients that must exist before the webapp can build
HALSCOPE_GEN_TS := $(WEBAPP_DIR)/halscope/src/generated/halscope_client.ts \
	$(WEBAPP_DIR)/halscope/src/generated/halscope_watch_client.ts

$(HALSCOPE_WEBAPP_STAMP): $(HALSCOPE_WEBAPP_SRCS) $(HALSCOPE_NPM_STAMP) $(HALSCOPE_GEN_TS)
	$(ECHO) "Building halscope webapp"
	$(Q)rm -rf $(HALSCOPE_WEBAPP_DEST)
	$(Q)cd $(HALSCOPE_WEBAPP_SRC) && npx vite build --outDir $(abspath $(HALSCOPE_WEBAPP_DEST)) --emptyOutDir
	$(Q)touch $@

TARGETS += $(HALSCOPE_WEBAPP_STAMP)

