#!/bin/bash
# halrun — compatibility shim for the gomc fork.
#
# The classic standalone `halrun` (start realtime, run a HAL file, tear down)
# was removed when HAL/realtime moved in-process into gomc-server.  This shim
# forwards to gomc-server's one-shot HAL-file mode so that the runtests suite
# and manual `halrun -f file.hal` invocations keep working.
#
# Only the `-f <file>` form used by the test suite is supported here; other
# classic halrun options are not implemented.

usage() {
    echo "Usage: halrun -f <halfile>" >&2
    exit 1
}

# Common case: `halrun -f file.hal` (optionally with a leading -I/-k that the
# test suite does not use).  Pass through to gomc-server, which understands -f.
case "$1" in
    -f)
        [ -n "$2" ] || usage
        exec gomc-server -f "$2"
        ;;
    "" | -h | --help)
        usage
        ;;
    *)
        # Fall back to forwarding all arguments; gomc-server parses -f itself.
        exec gomc-server "$@"
        ;;
esac
