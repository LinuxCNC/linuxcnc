#!/bin/bash
################################################################################
# usage: linuxcnc [options] [<INI file>]
#
# Thin wrapper that ensures the environment is set up (via rip-environment
# for RIP builds) and delegates all work to the Go-based linuxcnc-launcher.
#
################################################################################
# Author:
# License: GPL Version 2
# System: Linux
#
# Copyright (c) 2004-2009 All rights reserved.
################################################################################

# For RIP builds: if the environment has not been sourced yet, re-exec
# through rip-environment so that PATH, LD_LIBRARY_PATH, PYTHONPATH,
# TCLLIBPATH, etc. are all set up.
if test "xyes" = "x@RUN_IN_PLACE@"; then
    if test "${EMC2_HOME:-}" != "@EMC2_HOME@"; then
        exec @EMC2_HOME@/scripts/rip-environment linuxcnc "$@"
    fi
fi

# Force pyopengl (python3-opengl) to use its GLX backend, even
# if we're running on Wayland where it would normally use EGL.
# Similar for the Gtk and Qt backends.
# This must be set before any GUI subprocess is launched.
if [[ ! -v LINUXCNC_OPENGL_PLATFORM || "${LINUXCNC_OPENGL_PLATFORM}" == "glx" ]]; then
    export PYOPENGL_PLATFORM="x11"
    export GDK_BACKEND="x11"
    export QT_QPA_PLATFORM="xcb"
fi

exec @EMC2_BIN_DIR@/linuxcnc-launcher "$@"
