net  dRAD              sedm.RADf             techGui.RAD
net  dSPA              sedm.SPAf             techGui.SPA

net  dOrbitType         sedm.OrbitType
net  dWiglRADf          sedm.WiglRADf
net  dPlungeOrbitWanted sedm.PlungeOrbitWanted

net  dPitch             sedm.Pitch

net  dUNS               sedm.UNSf         techGui.UNS
net  dThisRad           sedm.ThisRADf     techGui.ThisRAD

net  dEtabNum         sedm.EtabNum          techGui.EtabNum

# 04.02.2026 no more techGui BegNR EndNR

net eox sedm.XOffsetCmd  axis.x.eoffset-counts
net eoy sedm.YOffsetCmd  axis.y.eoffset-counts
net eoz sedm.ZOffsetCmd  axis.z.eoffset-counts

#15.02.2026 not used setp sedm.PulseCount 0
setp sedm.freebies   20 #12

net die sedm.abort halui.abort

# 02.02.2026 TODO need trhhisvvv??? i got disableOsc
