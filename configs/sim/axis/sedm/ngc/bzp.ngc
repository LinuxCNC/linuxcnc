#11 = -3.00 ; CP;lane in G53  abso m.c coords
#12 = -1.0 ;RPlane rel to Datum

o200 sub
	M66 E0 L0 ;NEED QBUSTER AND sleep(0.010) in rComp BOTH
	M199
	M162 P1.254 Q-1.000 ;fd -1.254  RPlane 1.000
	M163 P1 Q0.01; orbtype wiglrad
	M160 P34 Q.254; etab filename msrdUNS
	M161 P15 Q15
	M166 P0 ; no jump
	M165 P1	; pitch
	g4p2
	M00
	M198
o200 endsub

;///////////////////// PREAMBLE
G21                      ; mm 
G17 ; NECC TO BE AWARE OFTOOL AXIS
G90
G61                       ; exact path mode
G64 P0                    ; set blend toleranve to 0
F5000 ; wishful thinnking

g10l2p1x0y0z0; UNSHIFT simplify dro to G53

;//////////////////// Posn 1

G53G0Z#11; Cplane in abso/mc coords

G10L2P1X5Y5Z-2 ; NEW DATUM   toolaxis at work surface in abso/mc coords

g0z#12;RPlane rel to Datum
G0X0Y0 ; move to ctr

; RPlane handl;ed by comp

