; SEDM-1x.ngc
; 01.12.2025
o200 sub
	M66 E0 L0             ; NEED QBUSTER AND sleep(0.010) in rComp BOTH
	M199                  ; begin EDM mode  by collectinf data from  Mxcodes
	M162 P-1.304 Q1.0     ; now Q is RPlane 
	M163 P0 Q0.05         ; P orbtype(0 circ 1sqr) Q wiglRAD
	M160 P34 Q0.254 ; P Etab Q MsrdUNS
	M161 P25 Q15          ; P BegNR W EndMR
	M166 P0               ; jump OFF
	M165 P1               ; pitch 1
	M00                   ' necc for offsets while paused
	M198                  ; end EDM modde
o200 endsub

;///////////////////// PREAMBLE
G21                       ; mm 
G90
G61                       ; exact path mode
G64 P0                    ; set blend toleranve to 0
F5000                     ; wishful thinnking

; //////////////////// Posn 1
g10l2p1 x0 y0 z0; UNshift
G53  G0       Z3; keep constant ht in wk area
g10l2p1 x1 y0 z2; add shift, mder from HERE
g0      x0 y0   ; get to new rwf pt (fromn g10 l2 p1....
z1				; move 1mm above ref pt (RPlane)
;
o200 call
;
; UNshift
G10l2p1x0y0z0
; goto safe posn
G0Z3
G0X0Y0
; ////////// end pgm
M02
%
