o200 sub
	M66 E0 L0 ;NEED QBUSTER AND sleep(0.010) in rComp BOTH
	M199
	
	M162 P-1.254 Q1.000 ;fd -1.254  RPlane 1.000
	
	M163 P0 Q0.005
	M160 P34 Q.254; etab filename msrdUNS
	M161 P25 Q24
	M166 P0 ; no jump
	M165 P1	; pitch
	;g4p2
	M00
	M198
o200 endsub

;///////////////////// PREAMBLE
G21                       ; mm 
G90
G17
G61                       ; exact path mode
G64 P0                    ; set blend toleranve to 0
F5000 ; wishful thinnking

g10l2p1x0y0z0; UNSHIFT simplify dro to G53
G0X-2Y2Z3 ; CPlane
;//////////////////// Posn 1
