# in case they were linked already
unlinkp iocontrol.tool-change
unlinkp iocontrol.tool-changed

# Need a qt tool change dialog added to screen for this to work
# though it uses the same pin names as the AXIS version
# the Qt version integrates better.

net tool-change manualtoolchange.change iocontrol.tool-change
net tool-changed manualtoolchange.changed iocontrol.tool-changed
net tool-prep-number manualtoolchange.number iocontrol.tool-prep-number
