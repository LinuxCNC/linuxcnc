# Replay 9 mixed-type (bfsu) samples through a loopback into a depth-10 ring,
# clocked for 12 ticks: the ring round-trips the 9 samples then underruns 3 times.
load filestream stream_cfg=bfsu infile=in.txt sample_cfg=bfsu outfile=out.txt depth=10 samples=12
newthread t 1000000
net a filestream.stream.0 => filestream.sample.0
net b filestream.stream.1 => filestream.sample.1
net c filestream.stream.2 => filestream.sample.2
net d filestream.stream.3 => filestream.sample.3
addf filestream.write t
addf filestream.read t
