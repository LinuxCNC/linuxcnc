TESTDIR="$(cd "$(dirname "$0")" && pwd)"
REPOROOT="$(cd "$TESTDIR/../.." && pwd)"

for cmd in python3.13 python3 python; do
    if command -v "$cmd" >/dev/null 2>&1; then
        PYTHON="$cmd"
        break
    fi
done

[ -z "$PYTHON" ] && { echo "SKIP: No Python interpreter found"; exit 0; }

QT_QPA_PLATFORM=offscreen \
PYTHONPATH="$REPOROOT/lib/python:$REPOROOT/scripts:$PYTHONPATH" \
"$PYTHON" "$TESTDIR/test.py"
