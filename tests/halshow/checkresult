ACTUAL="$1"
[ -z "$ACTUAL" ] || [ ! -f "$ACTUAL" ] && { echo "no output file"; exit 1; }

grep -q "^SKIP:" "$ACTUAL" && { echo "SKIPPED"; exit 0; }
grep -q "^OK:" "$ACTUAL" || { echo "FAILED: no OK results"; exit 1; }
grep -q "^FAILURES" "$ACTUAL" && { echo "FAILED"; exit 1; }

echo "PASSED"
exit 0
