
# sample where motion tells us to go

load sampler depth=1000 cfg=fffffffff

addf sampler              servo-thread

net Xpos => sampler.pin.0
net Ypos => sampler.pin.1
net Zpos => sampler.pin.2
net Xvel => sampler.pin.3
net Yvel => sampler.pin.4
net Zvel => sampler.pin.5
net Xacc => sampler.pin.6
net Yacc => sampler.pin.7
net Zacc => sampler.pin.8

