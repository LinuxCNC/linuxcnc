# HAL setup for the abs test — loaded by test.sh into a resident gomc-server.
# Feeds a streamer through abs into a sampler; the driver primes the streamer,
# starts threads, then captures the sampler.  (No 'start'/loadusr here.)
setexact_for_test_suite_only
load filestream stream_cfg=f infile=in.txt sample_cfg=ff outfile=out.txt depth=350 samples=7
load abs <abs.0>
newthread fast 100000
net in filestream.stream.0 => filestream.sample.0 abs.0.in
net out abs.0.out => filestream.sample.1
addf filestream.write fast
addf abs.0 fast
addf filestream.read fast
