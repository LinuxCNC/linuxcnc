setexact_for_test_suite_only
newthread fast 100000
loadrt biquad
loadrt sampler cfg=bff depth=500
loadrt streamer cfg=bf depth=500
net enable streamer.pin.0 => sampler.pin.0 biquad.enable
net in     streamer.pin.1 => sampler.pin.1 biquad.in
net out    biquad.out      => sampler.pin.2
addf streamer fast
addf biquad   fast
addf sampler  fast
