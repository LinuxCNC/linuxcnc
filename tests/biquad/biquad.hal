setexact_for_test_suite_only
newthread fast 100000
loadrt biquad
load filestream stream_cfg=bf infile=in.txt sample_cfg=bff outfile=out.txt depth=500 samples=10
net enable filestream.stream.0 => filestream.sample.0 biquad.enable
net in     filestream.stream.1 => filestream.sample.1 biquad.in
net out    biquad.out      => filestream.sample.2
addf filestream.write fast
addf biquad   fast
addf filestream.read  fast
