setexact_for_test_suite_only

load filestream sample_cfg=f outfile=out.txt depth=4096 samples=800 tag
load limit3
#loadrt blocks limit3=1
newthread t 1000000
setp limit3.maxv 500.000000
setp limit3.maxa 1000
setp limit3.max 160

net n0 limit3.out filestream.sample.0

addf limit3 t
addf filestream.read t

setp limit3.in 500

