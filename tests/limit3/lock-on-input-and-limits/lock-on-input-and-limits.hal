setexact_for_test_suite_only

#loadrt sampler cfg=fffffffu depth=1700
loadrt sampler cfg=ffff depth=3200

load limit3
setp limit3.min -50
setp limit3.max 50
setp limit3.maxv 4000
setp limit3.maxa 10000

load siggen <siggen.0>
setp siggen.0.amplitude 100

net in => limit3.in
net in => sampler.pin.0
net in <= siggen.0.triangle

net out <= limit3.out
net out => sampler.pin.1

load ddt <vel,acc>
net out => vel.in
net vel <= vel.out => sampler.pin.2 => acc.in
net acc <= acc.out => sampler.pin.3

newthread t 1000000

addf sampler t
addf siggen.0 t
addf limit3 t
addf vel t
addf acc t


