setexact_for_test_suite_only

load filestream sample_cfg=ffff outfile=out.txt depth=3200 samples=800 tag

load limit3
setp limit3.min -50
setp limit3.max 50
setp limit3.maxv 4000
setp limit3.maxa 10000

load siggen <siggen.0>
setp siggen.0.amplitude 100

net in <= siggen.0.sine
net in => limit3.in
net in => filestream.sample.0

net out <= limit3.out
net out => filestream.sample.1

load ddt <vel,acc>
net out => vel.in
net vel <= vel.out => filestream.sample.2 => acc.in
net acc <= acc.out => filestream.sample.3

newthread t 1000000

addf siggen.0 t
addf limit3 t
addf vel t
addf acc t
addf filestream.read t


