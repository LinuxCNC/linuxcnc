newthread fast 100000
load and2 <and2.0>
load or2 <or2.0>
load not <not.0>
load mux2 <mux2.0>
load mux4 <mux4.0>

load filestream stream_cfg=bbbb infile=in.txt sample_cfg=bbbff outfile=out.txt depth=1000 samples=16


net a filestream.stream.0
net b filestream.stream.1
net c filestream.stream.2
net d filestream.stream.3

net a and2.0.in0
net b and2.0.in1
net n0 and2.0.out filestream.sample.0

net a or2.0.in0
net b or2.0.in1
net n1 or2.0.out filestream.sample.1

net a not.0.in
net n2 not.0.out filestream.sample.2

net a mux2.0.sel
net n3 mux2.0.out filestream.sample.3
setp mux2.0.in0 1
setp mux2.0.in1 2

net a mux4.0.sel0
net b mux4.0.sel1
net n4 mux4.0.out filestream.sample.4
setp mux4.0.in0 3
setp mux4.0.in1 4
setp mux4.0.in2 5
setp mux4.0.in3 6

addf filestream.write fast
addf and2.0 fast
addf or2.0 fast
addf not.0 fast
addf mux2.0 fast
addf mux4.0 fast
addf filestream.read fast

