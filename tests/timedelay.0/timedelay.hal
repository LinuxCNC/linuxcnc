load filestream sample_cfg=bb outfile=out.txt depth=100 samples=64 tag
load timedelay
load not <not.0>
newthread thread 1953125

setp timedelay.on-delay 0.0087890625
setp timedelay.off-delay 0.0166015625

net square not.0.out => timedelay.in filestream.sample.0
net delayed timedelay.out => not.0.in filestream.sample.1

addf not.0 thread
addf timedelay thread
addf filestream.read thread
