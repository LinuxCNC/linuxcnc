setexact_for_test_suite_only

newthread fast 100000
load edge <edge.0>

load filestream stream_cfg=b infile=in.txt sample_cfg=bbb outfile=out.txt depth=500 samples=10

net in         filestream.stream.0  => filestream.sample.0 edge.0.in
net out        edge.0.out        => filestream.sample.1
net out-invert edge.0.out-invert => filestream.sample.2

addf filestream.write fast
addf edge.0     fast
addf filestream.read  fast

# look for falling edges
setp edge.0.in-edge True

# keep the .out pin high for 25,000 ns, rounded up to the nearest thread period
setp edge.0.out-width-ns 25000

