setexact_for_test_suite_only

newthread fast 100000
load edge <edge.0>

loadrt sampler cfg=bbb depth=500
loadrt streamer cfg=b depth=500

net in         streamer.pin.0  => sampler.pin.0 edge.0.in
net out        edge.0.out        => sampler.pin.1
net out-invert edge.0.out-invert => sampler.pin.2

addf streamer fast
addf edge.0     fast
addf sampler  fast

# look for falling edges
setp edge.0.in-edge True

# keep the .out pin high for 25,000 ns, rounded up to the nearest thread period
setp edge.0.out-width-ns 25000

