#!/bin/bash
# Confirm the failing prolog aborted the remap and conveyed the error, and that
# the NGC body never ran.
D=$(dirname "$1"); LOG="$D/server.log"
set -e
grep -q "test_remap_fail: failingprolog/failingepilog/mark_body registered" "$LOG"
grep -q "test_remap_fail: prolog failing with INTERP_ERROR" "$LOG"
grep -q "A failed C prolog returning INTERP_ERROR" "$LOG"
# the NGC body must NOT have executed (prolog fails first)
! grep -q "test_remap_fail: body executed" "$LOG"
echo "remap fail/prolog: prolog failed, error conveyed, NGC body not run"
